    "semantic": {
        "$description": "Shared semantic color tokens referencing core primitives. Properties define additional semantics in their own repos. Reference syntax: {family.shade} or {utility.name}. In dark mode, resolve the same references against primitives-dark.json.",
        "$product": "core",
        "tokens": {
            "brand-violet": "{violet.700}",
            "brand-orange": "{orange.600}",
            "brand-blue": "{blue.800}",
            "brand-yellow": "#fed05d",
            "info": "{blue.800}",
            "success": "{green.800}",
            "warning": "{yellow.800}",
            "failure": "{red.800}",
            "disabled": "{gray.500}",
            "text-body": "{gray.950}",
            "text-heading": "{gray.700}",
            "text-detail": "{gray.800}",
            "text-sub-heading": "{gray.800}",
            "foreground": "{utility.service-black}",
            "foreground-muted": "{gray.700}",
            "background": "#ffffff"
        }
    },
